FROM python:3.11-slim

WORKDIR /app

# System dependencies (minimal for UI)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc && \
    rm -rf /var/lib/apt/lists/*

# Install only UI-relevant Python packages
COPY requirements.txt .
RUN pip install --no-cache-dir streamlit requests httpx numpy

# Application code
COPY client/ client/

# Create non-root user
RUN useradd -m chatdft && chown -R chatdft:chatdft /app
USER chatdft

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import requests; r=requests.get('http://localhost:8501/_stcore/health'); assert r.status_code==200"

CMD ["streamlit", "run", "client/app.py", "--server.port=8501", "--server.address=0.0.0.0"]
