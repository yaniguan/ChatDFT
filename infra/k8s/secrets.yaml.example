# infra/k8s/secrets.yaml.example
# Copy to secrets.yaml and fill in real values.
# For production, use sealed-secrets or External Secrets Operator instead.
#
# To apply: kubectl apply -f secrets.yaml -n chatdft

apiVersion: v1
kind: Secret
metadata:
  name: chatdft-secrets
  namespace: chatdft
type: Opaque
stringData:
  # Constructed from Terraform outputs: rds_endpoint + rds_password_secret
  DATABASE_URL: "postgresql+asyncpg://chatdft:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/chatdft_ase"

  # OpenAI API key for LLM calls
  OPENAI_API_KEY: "sk-..."

  # HPC cluster SSH connection
  HPC_HOST: "hoffman2.idre.ucla.edu"
  HPC_USER: "your_username"
  REMOTE_BASE: "/u/home/your_username/chatdft"

---
# SSH key for HPC access (mount as volume)
apiVersion: v1
kind: Secret
metadata:
  name: chatdft-ssh-key
  namespace: chatdft
type: Opaque
data:
  # base64-encoded SSH private key:
  #   cat ~/.ssh/id_rsa | base64 -w0
  id_rsa: "BASE64_ENCODED_SSH_PRIVATE_KEY"
