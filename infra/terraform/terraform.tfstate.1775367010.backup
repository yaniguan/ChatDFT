            "description": "Provides permissions for AWS Load Balancer Controller addon",
            "id": "arn:aws:iam::364585379072:policy/AmazonEKS_AWS_Load_Balancer_Controller-20260405051352818300000005",
            "name": "AmazonEKS_AWS_Load_Balancer_Controller-20260405051352818300000005",
